{
  "name": "Vendor Invoice",
  "doctype": "DocType",
  "module": "Chakra",
  "engine": "InnoDB",
  "autoname": "format:VINV-{####}",
  "title_field": "invoice_number",
  "search_fields": "invoice_number,project,vendor_user",
  "fields": [
    {
      "fieldname": "vendor_user",
      "fieldtype": "Link",
      "label": "Vendor User",
      "options": "User",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "invoice_number",
      "fieldtype": "Data",
      "label": "Invoice Number",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "label": "Project",
      "options": "FF Project",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "invoice_date",
      "fieldtype": "Date",
      "label": "Invoice Date",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "period_start",
      "fieldtype": "Date",
      "label": "Period Start",
      "reqd": 1
    },
    {
      "fieldname": "period_end",
      "fieldtype": "Date",
      "label": "Period End",
      "reqd": 1
    },
    {
      "fieldname": "amount",
      "fieldtype": "Currency",
      "label": "Amount",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Submitted\nApproved\nPaid\nRejected",
      "default": "Submitted",
      "in_list_view": 1
    },
    {
      "fieldname": "payment_reference",
      "fieldtype": "Data",
      "label": "Payment Reference"
    },
    {
      "fieldname": "payment_date",
      "fieldtype": "Date",
      "label": "Payment Date"
    },
    {
      "fieldname": "processed_by",
      "fieldtype": "Data",
      "label": "Processed By",
      "read_only": 1
    },
    {
      "fieldname": "processed_on",
      "fieldtype": "Datetime",
      "label": "Processed On",
      "read_only": 1
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "report": 1,
      "export": 1
    },
    {
      "role": "FF Vendor",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "report": 1
    },
    {
      "role": "FF Chief",
      "read": 1,
      "write": 1,
      "create": 0,
      "delete": 0,
      "report": 1
    }
  ]
}
